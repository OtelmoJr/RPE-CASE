<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>transform_selic</name>
    <description>tab_raw para tab_final — 7 operacoes de transformacao usando steps nativos</description>
    <extended_description>
      Le dados brutos da tab_raw (API BCB serie 11) no DuckDB, aplica 7 transformacoes
      com steps nativos (sem JavaScript) e grava o resultado em tab_final.
    </extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters/>
    <log>
      <trans-log-table><connection/><schema/><table/><size_limit_lines/><interval/><timeout_days/></trans-log-table>
    </log>
    <maxdate><connection/><table/><field/><offset>0.0</offset><maxdiff>0.0</maxdiff></maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <created_user>admin</created_user>
    <created_date>2024/01/01 00:00:00.000</created_date>
    <modified_user>admin</modified_user>
    <modified_date>2024/01/01 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAAAAMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>

  <!-- ============================================================ -->
  <!-- Conexao DuckDB via JDBC generico                             -->
  <!-- ============================================================ -->
  <connection>
    <name>duckdb_selic</name>
    <server/>
    <type>GENERIC</type>
    <access>Native</access>
    <database/>
    <port>-1</port>
    <username/>
    <password/>
    <servername/>
    <data_tablespace/>
    <index_tablespace/>
    <attributes>
      <attribute><code>CUSTOM_DRIVER_CLASS</code><attribute>org.duckdb.DuckDBDriver</attribute></attribute>
      <attribute><code>CUSTOM_URL</code><attribute>jdbc:duckdb:/opt/airflow/data/selic.duckdb</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_LOWERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_UPPERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>IS_CLUSTERED</code><attribute>N</attribute></attribute>
      <attribute><code>PRESERVE_RESERVED_WORD_CASE</code><attribute>Y</attribute></attribute>
      <attribute><code>QUOTE_ALL_FIELDS</code><attribute>N</attribute></attribute>
      <attribute><code>SUPPORTS_BOOLEAN_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_TIMESTAMP_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>USE_POOLING</code><attribute>N</attribute></attribute>
    </attributes>
  </connection>

  <!-- ============================================================ -->
  <!-- Ordem dos hops (pipeline linear)                             -->
  <!-- ============================================================ -->
  <order>
    <hop><from>Ler tab_raw</from><to>Filtrar Nulos</to><enabled>Y</enabled></hop>
    <hop><from>Filtrar Nulos</from><to>Renomear e Converter Tipos</to><enabled>Y</enabled></hop>
    <hop><from>Renomear e Converter Tipos</from><to>Extrair Componentes Data</to><enabled>Y</enabled></hop>
    <hop><from>Extrair Componentes Data</from><to>Anualizar Selic</to><enabled>Y</enabled></hop>
    <hop><from>Anualizar Selic</from><to>Classificar e Descrever</to><enabled>Y</enabled></hop>
    <hop><from>Classificar e Descrever</from><to>Indicador Constante</to><enabled>Y</enabled></hop>
    <hop><from>Indicador Constante</from><to>Gravar tab_final</to><enabled>Y</enabled></hop>
  </order>

  <!-- ============================================================ -->
  <!-- STEP 1: Table Input — leitura bruta de tab_raw               -->
  <!-- ============================================================ -->
  <step>
    <name>Ler tab_raw</name>
    <type>TableInput</type>
    <description>Leitura dos dados brutos da tabela tab_raw</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <connection>duckdb_selic</connection>
    <sql>SELECT data, valor FROM tab_raw WHERE valor IS NOT NULL AND valor != ''</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>80</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 2: Filter Rows — OP1: filtro de nulos/vazios            -->
  <!-- ============================================================ -->
  <step>
    <name>Filtrar Nulos</name>
    <type>FilterRows</type>
    <description>OP1: Remove registros com valor nulo ou vazio</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <send_true_to>Renomear e Converter Tipos</send_true_to>
    <send_false_to/>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>valor</leftvalue>
            <function>IS NOT NULL</function>
            <rightvalue/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>valor</leftvalue>
            <function>&lt;&gt;</function>
            <rightvalue/>
            <value><name>constant</name><type>String</type><text/></value>
          </condition>
        </conditions>
      </condition>
    </compare>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>240</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 3: Select Values — OP2 + OP3: converter data e valor    -->
  <!-- ============================================================ -->
  <step>
    <name>Renomear e Converter Tipos</name>
    <type>SelectValues</type>
    <description>OP2: data string para Date. OP3: valor string para Number</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <fields>
      <field><name>data</name><rename>data_original</rename></field>
      <field><name>data</name><rename>data_formatada</rename></field>
      <field><name>valor</name><rename>valor_diario</rename></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <meta>
      <changes>
        <change>
          <name>data_formatada</name>
          <rename>data_formatada</rename>
          <type>Date</type>
          <length>-2</length>
          <precision>-2</precision>
          <conversion_mask>dd/MM/yyyy</conversion_mask>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol>.</decimal_symbol>
          <grouping_symbol>,</grouping_symbol>
          <currency_symbol/>
          <storage_type/>
        </change>
        <change>
          <name>valor_diario</name>
          <rename>valor_diario</rename>
          <type>Number</type>
          <length>10</length>
          <precision>6</precision>
          <conversion_mask>#.######</conversion_mask>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol>.</decimal_symbol>
          <grouping_symbol>,</grouping_symbol>
          <currency_symbol/>
          <storage_type/>
        </change>
      </changes>
    </meta>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>400</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 4: Calculator — OP4: extrair ano, mes, dia              -->
  <!-- ============================================================ -->
  <step>
    <name>Extrair Componentes Data</name>
    <type>Calculator</type>
    <description>OP4: ano, mes e dia a partir de data_formatada</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <failIfNoFile>Y</failIfNoFile>
    <calculation>
      <field_name>ano</field_name>
      <calc_type>YEAR_OF_DATE</calc_type>
      <field_a>data_formatada</field_a><field_b/><field_c/>
      <value_type>Integer</value_type>
      <value_length>4</value_length><value_precision>0</value_precision>
      <remove>N</remove>
      <conversion_mask/><decimal_format/><grouping_format/><currency_format/>
    </calculation>
    <calculation>
      <field_name>mes</field_name>
      <calc_type>MONTH_OF_DATE</calc_type>
      <field_a>data_formatada</field_a><field_b/><field_c/>
      <value_type>Integer</value_type>
      <value_length>2</value_length><value_precision>0</value_precision>
      <remove>N</remove>
      <conversion_mask/><decimal_format/><grouping_format/><currency_format/>
    </calculation>
    <calculation>
      <field_name>dia</field_name>
      <calc_type>DAY_OF_MONTH</calc_type>
      <field_a>data_formatada</field_a><field_b/><field_c/>
      <value_type>Integer</value_type>
      <value_length>2</value_length><value_precision>0</value_precision>
      <remove>N</remove>
      <conversion_mask/><decimal_format/><grouping_format/><currency_format/>
    </calculation>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>560</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 5: Formula — OP5: anualizacao da Selic (step nativo)    -->
  <!-- Substitui o Modified JavaScript antigo por calculo nativo.   -->
  <!-- Formula: ((1 + taxa/100) ^ 252 - 1) * 100                   -->
  <!-- ============================================================ -->
  <step>
    <name>Anualizar Selic</name>
    <type>Formula</type>
    <description>OP5: anualizacao — POWER nativo em vez de JavaScript</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <formula>
      <formula_string>(POWER(1+[valor_diario]/100;252)-1)*100</formula_string>
      <formula_type>Number</formula_type>
      <formula_length>10</formula_length>
      <formula_precision>4</formula_precision>
      <field_name>valor_anualizado</field_name>
      <replace_field/>
    </formula>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>720</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 6: Formula — OP6 + OP7: classificacao + descricao       -->
  <!-- IF nativo substitui o bloco de JavaScript condicional.       -->
  <!-- ============================================================ -->
  <step>
    <name>Classificar e Descrever</name>
    <type>Formula</type>
    <description>OP6: classificacao condicional. OP7: concatenacao descricao</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <formula>
      <formula_string>IF([valor_anualizado]&gt;13;"ALTA";IF([valor_anualizado]&gt;=10;"MODERADA";"BAIXA"))</formula_string>
      <formula_type>String</formula_type>
      <formula_length>20</formula_length>
      <formula_precision>-1</formula_precision>
      <field_name>classificacao</field_name>
      <replace_field/>
    </formula>
    <formula>
      <formula_string>CONCATENATE("TAXA SELIC - ";[classificacao])</formula_string>
      <formula_type>String</formula_type>
      <formula_length>100</formula_length>
      <formula_precision>-1</formula_precision>
      <field_name>descricao</field_name>
      <replace_field/>
    </formula>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>880</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 7: Add Constants — OP7 (cont): indicador = "SELIC"     -->
  <!-- ============================================================ -->
  <step>
    <name>Indicador Constante</name>
    <type>Constant</type>
    <description>OP7: campo fixo indicador = SELIC</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <fields>
      <field>
        <name>indicador</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <nullif>SELIC</nullif>
        <length>50</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>1040</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 8: Table Output — gravar resultado em tab_final         -->
  <!-- ============================================================ -->
  <step>
    <name>Gravar tab_final</name>
    <type>TableOutput</type>
    <description>Grava dados transformados em tab_final (DuckDB)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <connection>duckdb_selic</connection>
    <schema/>
    <table>tab_final</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field><column_name>data_original</column_name><stream_name>data_original</stream_name></field>
      <field><column_name>data_formatada</column_name><stream_name>data_formatada</stream_name></field>
      <field><column_name>ano</column_name><stream_name>ano</stream_name></field>
      <field><column_name>mes</column_name><stream_name>mes</stream_name></field>
      <field><column_name>dia</column_name><stream_name>dia</stream_name></field>
      <field><column_name>valor_diario</column_name><stream_name>valor_diario</stream_name></field>
      <field><column_name>valor_anualizado</column_name><stream_name>valor_anualizado</stream_name></field>
      <field><column_name>classificacao</column_name><stream_name>classificacao</stream_name></field>
      <field><column_name>descricao</column_name><stream_name>descricao</stream_name></field>
      <field><column_name>indicador</column_name><stream_name>indicador</stream_name></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>1200</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step_error_handling/>
  <slave-step-copy-partition-distribution/>
  <slave_transformation>N</slave_transformation>
</transformation>
