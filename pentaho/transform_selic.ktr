<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>transform_selic</name>
    <description>tab_raw para tab_final â€” transformacao com steps nativos do Pentaho</description>
    <extended_description>
      Le dados brutos da tab_raw (API BCB serie 11) no DuckDB, aplica transformacoes
      (formatacao de data, extracao de componentes, anualizacao, classificacao) via SQL
      analitico no DuckDB, valida com FilterRows, converte tipos com SelectValues,
      adiciona campo constante e grava o resultado em tab_final.
    </extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters/>
    <log>
      <trans-log-table><connection/><schema/><table/><size_limit_lines/><interval/><timeout_days/></trans-log-table>
    </log>
    <maxdate><connection/><table/><field/><offset>0.0</offset><maxdiff>0.0</maxdiff></maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <created_user>admin</created_user>
    <created_date>2024/01/01 00:00:00.000</created_date>
    <modified_user>admin</modified_user>
    <modified_date>2024/01/01 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAAAAMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>

  <!-- ============================================================ -->
  <!-- Conexao DuckDB via JDBC generico                             -->
  <!-- ============================================================ -->
  <connection>
    <name>duckdb_selic</name>
    <server/>
    <type>GENERIC</type>
    <access>Native</access>
    <database/>
    <port>-1</port>
    <username/>
    <password/>
    <servername/>
    <data_tablespace/>
    <index_tablespace/>
    <attributes>
      <attribute><code>CUSTOM_DRIVER_CLASS</code><attribute>org.duckdb.DuckDBDriver</attribute></attribute>
      <attribute><code>CUSTOM_URL</code><attribute>jdbc:duckdb:/opt/airflow/data/selic.duckdb</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_LOWERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_UPPERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>IS_CLUSTERED</code><attribute>N</attribute></attribute>
      <attribute><code>PRESERVE_RESERVED_WORD_CASE</code><attribute>Y</attribute></attribute>
      <attribute><code>QUOTE_ALL_FIELDS</code><attribute>N</attribute></attribute>
      <attribute><code>SUPPORTS_BOOLEAN_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_TIMESTAMP_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>USE_POOLING</code><attribute>N</attribute></attribute>
    </attributes>
  </connection>

  <!-- ============================================================ -->
  <!-- Ordem dos hops (pipeline linear de 5 steps)                  -->
  <!-- ============================================================ -->
  <order>
    <hop><from>Consulta Analitica</from><to>Filtrar Nulos</to><enabled>Y</enabled></hop>
    <hop><from>Filtrar Nulos</from><to>Validar Tipos</to><enabled>Y</enabled></hop>
    <hop><from>Validar Tipos</from><to>Indicador Constante</to><enabled>Y</enabled></hop>
    <hop><from>Indicador Constante</from><to>Gravar tab_final</to><enabled>Y</enabled></hop>
  </order>

  <!-- ============================================================ -->
  <!-- STEP 1: Table Input â€” query analitica com todas as           -->
  <!-- transformacoes: formatacao de data, extracao de componentes,  -->
  <!-- conversao de tipos, anualizacao POWER e classificacao CASE.  -->
  <!-- ============================================================ -->
  <step>
    <name>Consulta Analitica</name>
    <type>TableInput</type>
    <description>Leitura e transformacao via SQL analitico no DuckDB</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <connection>duckdb_selic</connection>
    <sql>SELECT
  t.data_original,
  t.data_formatada,
  t.ano,
  t.mes,
  t.dia,
  t.valor_diario,
  t.valor_anualizado,
  CASE
    WHEN t.valor_anualizado > 13 THEN 'ALTA'
    WHEN t.valor_anualizado >= 10 THEN 'MODERADA'
    ELSE 'BAIXA'
  END AS classificacao,
  'TAXA SELIC - ' || CASE
    WHEN t.valor_anualizado > 13 THEN 'ALTA'
    WHEN t.valor_anualizado >= 10 THEN 'MODERADA'
    ELSE 'BAIXA'
  END AS descricao
FROM (
  SELECT
    data AS data_original,
    strftime(strptime(data, '%d/%m/%Y'), '%Y-%m-%d') AS data_formatada,
    EXTRACT(YEAR FROM strptime(data, '%d/%m/%Y'))::INTEGER AS ano,
    EXTRACT(MONTH FROM strptime(data, '%d/%m/%Y'))::INTEGER AS mes,
    EXTRACT(DAY FROM strptime(data, '%d/%m/%Y'))::INTEGER AS dia,
    CAST(valor AS DOUBLE) AS valor_diario,
    (POWER(1 + CAST(valor AS DOUBLE)/100, 252) - 1) * 100 AS valor_anualizado
  FROM tab_raw
  WHERE valor IS NOT NULL AND TRIM(valor) != ''
) t</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>80</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 2: Filter Rows â€” validacao de qualidade de dados        -->
  <!-- ============================================================ -->
  <step>
    <name>Filtrar Nulos</name>
    <type>FilterRows</type>
    <description>Garante que nenhum registro com valor nulo passe adiante</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <send_true_to>Validar Tipos</send_true_to>
    <send_false_to/>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>valor_diario</leftvalue>
            <function>IS NOT NULL</function>
            <rightvalue/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>280</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 3: Select Values â€” validacao e conversao de tipos       -->
  <!-- ============================================================ -->
  <step>
    <name>Validar Tipos</name>
    <type>SelectValues</type>
    <description>Seleciona campos e forca tipos corretos para gravacao</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <fields>
      <field><name>data_original</name></field>
      <field><name>data_formatada</name></field>
      <field><name>ano</name></field>
      <field><name>mes</name></field>
      <field><name>dia</name></field>
      <field><name>valor_diario</name></field>
      <field><name>valor_anualizado</name></field>
      <field><name>classificacao</name></field>
      <field><name>descricao</name></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <meta>
      <changes>
        <change>
          <name>valor_diario</name>
          <rename>valor_diario</rename>
          <type>Number</type>
          <length>10</length>
          <precision>6</precision>
          <conversion_mask/>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol>.</decimal_symbol>
          <grouping_symbol/>
          <currency_symbol/>
          <storage_type>normal</storage_type>
        </change>
        <change>
          <name>valor_anualizado</name>
          <rename>valor_anualizado</rename>
          <type>Number</type>
          <length>10</length>
          <precision>4</precision>
          <conversion_mask/>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol>.</decimal_symbol>
          <grouping_symbol/>
          <currency_symbol/>
          <storage_type>normal</storage_type>
        </change>
        <change>
          <name>ano</name>
          <rename>ano</rename>
          <type>Integer</type>
          <length>4</length>
          <precision>0</precision>
          <conversion_mask/>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol/>
          <grouping_symbol/>
          <currency_symbol/>
          <storage_type>normal</storage_type>
        </change>
        <change>
          <name>mes</name>
          <rename>mes</rename>
          <type>Integer</type>
          <length>2</length>
          <precision>0</precision>
          <conversion_mask/>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol/>
          <grouping_symbol/>
          <currency_symbol/>
          <storage_type>normal</storage_type>
        </change>
        <change>
          <name>dia</name>
          <rename>dia</rename>
          <type>Integer</type>
          <length>2</length>
          <precision>0</precision>
          <conversion_mask/>
          <date_format_lenient>false</date_format_lenient>
          <date_format_locale/>
          <date_format_timezone/>
          <lenient_string_to_number>N</lenient_string_to_number>
          <encoding/>
          <decimal_symbol/>
          <grouping_symbol/>
          <currency_symbol/>
          <storage_type>normal</storage_type>
        </change>
      </changes>
    </meta>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>480</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 4: Add Constants â€” campo fixo indicador = "SELIC"       -->
  <!-- ============================================================ -->
  <step>
    <name>Indicador Constante</name>
    <type>Constant</type>
    <description>Adiciona campo indicador com valor fixo SELIC</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <fields>
      <field>
        <name>indicador</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <nullif>SELIC</nullif>
        <length>50</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>680</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 5: Table Output â€” gravar resultado em tab_final         -->
  <!-- ============================================================ -->
  <step>
    <name>Gravar tab_final</name>
    <type>TableOutput</type>
    <description>Grava dados transformados em tab_final (DuckDB)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type><schema_name/></partitioning>
    <connection>duckdb_selic</connection>
    <schema/>
    <table>tab_final</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field><column_name>data_original</column_name><stream_name>data_original</stream_name></field>
      <field><column_name>data_formatada</column_name><stream_name>data_formatada</stream_name></field>
      <field><column_name>ano</column_name><stream_name>ano</stream_name></field>
      <field><column_name>mes</column_name><stream_name>mes</stream_name></field>
      <field><column_name>dia</column_name><stream_name>dia</stream_name></field>
      <field><column_name>valor_diario</column_name><stream_name>valor_diario</stream_name></field>
      <field><column_name>valor_anualizado</column_name><stream_name>valor_anualizado</stream_name></field>
      <field><column_name>classificacao</column_name><stream_name>classificacao</stream_name></field>
      <field><column_name>descricao</column_name><stream_name>descricao</stream_name></field>
      <field><column_name>indicador</column_name><stream_name>indicador</stream_name></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>880</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step_error_handling/>
  <slave-step-copy-partition-distribution/>
  <slave_transformation>N</slave_transformation>
</transformation>
